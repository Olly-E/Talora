generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  author      String
  category    String
  coverImage  String
  readTime    String
  tags        String[]
  excerpt     String
  featured    Boolean  @default(false)
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime @default(now())

  @@index([category])
  @@index([featured])
  @@index([slug])
}

model CaseStudy {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  client      String
  industry    String
  description String
  challenge   String
  solution    String
  results     String[]
  coverImage  String
  tags        String[]
  featured    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([featured])
  @@index([industry])
  @@index([slug])
}

model Job {
  id              Int      @id @default(autoincrement())
  title           String
  slug            String   @unique
  company         String
  location        String
  type            String
  modeOfWork      String
  salary          String
  currency        String   @default("USD")
  category        String[]
  openings        Int
  posted          String
  description     String
  tags            String[]
  isUrgent        Boolean  @default(false)
  applicationLink String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isUrgent])
  @@index([slug])
  @@index([type])
}
